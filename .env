# glovewort phase-1 environment template
# OpenClaw is pinned to version 2026.4.2.

# --- Image contract ---
# Must point to a prebuilt image created from OpenClaw 2026.4.2.
OPENCLAW_BASE_IMAGE=openclaw-2026.4.2-base:local

# --- Telegram ingress ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_MODE=polling

# --- OpenClaw gateway ---
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CONFIG_PATH=/home/node/.openclaw/openclaw.config.yaml
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_MODEL_PROVIDER=ollama-bridge
OPENCLAW_MODEL_NAME=qwen2.5-coder:1.5b

# --- Bridge API ---
BRIDGE_API_KEY=
BRIDGE_PORT=8000
BRIDGE_TIMEOUT_SECONDS=180
BRIDGE_BASE_URL=http://llm-bridge-api:8000/v1

# --- Ollama brain ---
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# --- Compose / network ---
BRAIN_HAND_NETWORK=brain_hand_net
OLLAMA_DATA_VOLUME=ollama_data
