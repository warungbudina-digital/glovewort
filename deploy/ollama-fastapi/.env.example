# phase-1 deploy env for bridge + Ollama
# this subtree is finalized as a runtime-ready specification,
# but the full system is still not being executed yet.

# bridge auth
BRIDGE_API_KEY=

# bridge runtime
BRIDGE_PORT=8000
OLLAMA_TIMEOUT=180
DEFAULT_MODEL=qwen2.5-coder:1.5b

# ollama runtime
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# storage
OLLAMA_DATA_VOLUME=ollama_data
